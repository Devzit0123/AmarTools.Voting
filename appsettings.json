{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },

  // ── Connection string: set via environment variable or user-secrets ─────────
  // Never put real passwords here.
  // Dev:  dotnet user-secrets set "ConnectionStrings:VotingConnection" "Host=...;Password=...;"
  // Prod: set environment variable  ConnectionStrings__VotingConnection
  "ConnectionStrings": {
    "VotingConnection": ""
  },

  // ── Seed admin: set via environment variable or user-secrets ────────────────
  // dotnet user-secrets set "Seed:AdminEmail"    "admin@yoursite.com"
  // dotnet user-secrets set "Seed:AdminPassword" "YourStrongPassword!"
  "Seed": {
    "AdminEmail": "",
    "AdminPassword": ""
  }
}
