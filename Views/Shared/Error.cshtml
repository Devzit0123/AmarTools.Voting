@model AmarTools.Voting.Models.ErrorViewModel

@{
    ViewData["Title"] = "Error";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-lg-8 text-center">
            <h1 class="display-4 text-danger mb-4">
                <i class="bi bi-exclamation-triangle-fill me-2"></i>
                Error @Model.StatusCode
            </h1>

            <h2 class="text-danger mb-4">
                @if (!string.IsNullOrEmpty(Model.Message))
                {
                    @Model.Message
                }
                else
                {
                    @:An error occurred while processing your request.
                }
            </h2>

            @if (Model.ShowRequestId)
            {
                <div class="alert alert-info mb-4">
                    <strong>Request ID:</strong> <code>@Model.RequestId</code>
                    <br />
                    <small class="text-muted">Use this ID when contacting support.</small>
                </div>
            }

            @if (Model.ShowException && Model.ExceptionMessage != null)
            {
                <div class="alert alert-warning mb-4">
                    <strong>Details (development only):</strong>
                    <pre class="mb-0">@Model.ExceptionMessage</pre>
                </div>
            }

            <div class="card border-warning mb-4">
                <div class="card-header bg-warning text-dark fw-bold">
                    Development Mode
                </div>
                <div class="card-body">
                    <p>
                        In <strong>Development</strong> mode you see more detailed errors.
                        Do <strong>NOT</strong> enable this in production.
                    </p>
                    <p class="mb-0">
                        To enable locally:
                    </p>
                    <ul class="mt-2">
                        <li>Set <code>ASPNETCORE_ENVIRONMENT=Development</code></li>
                        <li>Restart the app</li>
                    </ul>
                </div>
            </div>

            <div class="mt-4">
                <a href="/" class="btn btn-primary btn-lg px-5">
                    <i class="bi bi-house-door me-2"></i> Back to Home
                </a>
            </div>
        </div>
    </div>
</div>