@model AmarTools.Voting.Models.VotingProgram
@inject Microsoft.AspNetCore.Http.IHttpContextAccessor HttpAccessor

@{
    var isEdit = Model?.Id > 0;
    ViewData["Title"] = isEdit ? "Edit Program" : "Create Program";
    var actionName = isEdit ? "Edit" : "Create";
    var controllerName = ViewContext.RouteData.Values["controller"]?.ToString() ?? "ProgramOwner";

    string? publishedLink = TempData["PublishedLink"] as string;
    if (string.IsNullOrEmpty(publishedLink) && isEdit && Model!.IsPublished)
    {
        var request = HttpAccessor.HttpContext?.Request;
        publishedLink = request != null
            ? Url.Action("Vote", "Voting", new { id = Model.Id }, request.Scheme)
            : null;
    }
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h2 class="fw-bold mb-1">@ViewData["Title"]</h2>
        <p class="text-muted mb-0">
            @(isEdit ? "Update the details of this voting program" : "Set up a new voting program")
        </p>
    </div>
    @if (controllerName == "VotingAdmin")
    {
        <a asp-controller="VotingAdmin" asp-action="Index" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left me-1"></i> Back to Dashboard
        </a>
    }
    else
    {
        <a asp-controller="ProgramOwner" asp-action="MyPrograms" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left me-1"></i> Back to My Programs
        </a>
    }
</div>

@if (!string.IsNullOrEmpty(publishedLink))
{
    <div class="alert alert-info d-flex align-items-center gap-3 mb-4" id="pub-alert">
        <i class="bi bi-link-45deg fs-4"></i>
        <div>
            <strong>Public voting link:</strong>
            <span id="pub-link-text" class="font-monospace small ms-2">@publishedLink</span>
        </div>
        <button class="btn btn-sm btn-outline-primary ms-auto" onclick="copyLink()">Copy</button>
    </div>
}

<div class="row g-4">
    <div class="col-lg-8">
        <div class="card border-0 shadow-sm">
            <div class="card-body p-4">
                <form asp-controller="@controllerName" asp-action="@actionName" method="post" id="programForm">
                    @Html.AntiForgeryToken()
                    @if (isEdit)
                    {
                        <input type="hidden" asp-for="Id" />
                    }

                    <div asp-validation-summary="ModelOnly" class="alert alert-danger py-3 mb-4 fw-semibold" role="alert"></div>

                    <div class="mb-3">
                        <label asp-for="ProgramName" class="form-label fw-semibold"></label> <span class="text-danger">*</span>
                        <input asp-for="ProgramName" class="form-control form-control-lg" placeholder="e.g. Student Council Election 2026" />
                        <span asp-validation-for="ProgramName" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Description" class="form-label fw-semibold"></label>
                        <textarea asp-for="Description" class="form-control" rows="4"
                                  placeholder="Describe the purpose and rules of this program..."></textarea>
                        <span asp-validation-for="Description" class="text-danger small"></span>
                    </div>

                    <div class="row g-3 mb-3">
                        <div class="col-md-6">
                            <label asp-for="StartTime" class="form-label fw-semibold"></label> <span class="text-danger">*</span>
                            <input asp-for="StartTime" asp-format="{0:yyyy-MM-ddTHH:mm}" type="datetime-local" class="form-control form-control-lg" />
                            <span asp-validation-for="StartTime" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="EndTime" class="form-label fw-semibold"></label> <span class="text-danger">*</span>
                            <input asp-for="EndTime" asp-format="{0:yyyy-MM-ddTHH:mm}" type="datetime-local" class="form-control form-control-lg" />
                            <span asp-validation-for="EndTime" class="text-danger small"></span>
                            <div class="form-text">End time must be at least 5 minutes after the start time.</div>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-semibold">
                            Custom URL Slug <span class="text-muted fw-normal">(optional)</span>
                        </label>
                        <input asp-for="Slug" class="form-control" placeholder="student-election-2026" />
                        <div class="form-text">Leave blank to use the standard ID-based voting link.</div>
                        <span asp-validation-for="Slug" class="text-danger small"></span>
                    </div>

                    <hr class="my-4" />

                    <div class="form-check mb-4">
                        <input asp-for="IsPublished" class="form-check-input" type="checkbox" />
                        <label asp-for="IsPublished" class="form-check-label fw-semibold">
                            Publish immediately
                            <span class="d-block text-muted fw-normal small">Make this program visible and open for voting</span>
                        </label>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary btn-lg">
                            <i class="bi bi-@(isEdit ? "save" : "check-lg") me-1"></i>
                            @(isEdit ? "Save Changes" : "Create Program")
                        </button>
                        @if (controllerName == "VotingAdmin")
                        {
                            <a asp-controller="VotingAdmin" asp-action="Index" class="btn btn-outline-secondary btn-lg">Cancel</a>
                        }
                        else
                        {
                            <a asp-controller="ProgramOwner" asp-action="MyPrograms" class="btn btn-outline-secondary btn-lg">Cancel</a>
                        }
                    </div>
                </form>
            </div>
        </div>
    </div>

    <div class="col-lg-4">
        <div class="card border-0 shadow-sm mb-3">
            <div class="card-header bg-white fw-semibold">💡 Tips</div>
            <div class="card-body small text-muted">
                <p><i class="bi bi-clock text-primary me-2"></i>Set times in your <strong>local timezone</strong>. The system converts to UTC automatically.</p>
                <p><i class="bi bi-people text-primary me-2"></i>Add candidates after creating the program.</p>
                <p class="mb-0"><i class="bi bi-eye text-primary me-2"></i>Publishing makes the program visible. You can unpublish at any time.</p>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        document.getElementById('programForm')?.addEventListener('submit', function (e) {
            const start = document.querySelector('[name="StartTime"]').value;
            const end = document.querySelector('[name="EndTime"]').value;
            if (start && end) {
                const startDate = new Date(start);
                const endDate = new Date(end);
                const minimumDifferenceMs = 5 * 60 * 1000;

                if (endDate.getTime() - startDate.getTime() < minimumDifferenceMs) {
                    e.preventDefault();
                    alert('End time must be at least 5 minutes after start time.');
                }
            }
        });

        function copyLink() {
            const text = document.getElementById('pub-link-text')?.textContent?.trim();
            if (text) {
                navigator.clipboard.writeText(text).then(() => {
                    const btn = document.querySelector('#pub-alert .btn');
                    if (btn) {
                        const original = btn.innerHTML;
                        btn.innerHTML = '<i class="bi bi-check-lg"></i> Copied!';
                        setTimeout(() => btn.innerHTML = original, 2000);
                    }
                });
            }
        }
    </script>
}
