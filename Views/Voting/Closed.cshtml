@model AmarTools.Voting.Models.VotingProgram

@{
    ViewData["Title"] = "Voting Not Available";
    Layout = "/Views/Shared/_PublicLayout.cshtml";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-7 col-xl-6">

            <div class="card shadow border-0 rounded-4 overflow-hidden">
                <div class="card-body text-center p-5">

                    <div style="font-size:5rem;opacity:0.8;" class="text-danger mb-3">
                        <i class="bi bi-lock-fill"></i>
                    </div>

                    <h2 class="fw-bold text-danger mb-3">Voting Not Available</h2>

                    <p class="lead text-muted mb-4">@(ViewBag.Message ?? "This voting program is not currently active.")</p>

                    @if (Model != null)
                    {
                        <div class="card bg-light border-0 rounded-3 mb-4 text-start">
                            <div class="card-body px-4 py-3">
                                <h5 class="fw-bold mb-2">@Model.ProgramName</h5>
                                @if (!string.IsNullOrWhiteSpace(Model.Description))
                                {
                                    <p class="text-muted small mb-3">@Model.Description</p>
                                }
                                <div class="small">
                                    <div class="d-flex justify-content-between border-bottom py-2">
                                        <span class="text-muted">Voting opens</span>
                                        <span class="fw-semibold">@(ViewBag.StartTimeLocal?.ToString("MMM dd, yyyy HH:mm") ?? "—")</span>
                                    </div>
                                    <div class="d-flex justify-content-between border-bottom py-2">
                                        <span class="text-muted">Voting closes</span>
                                        <span class="fw-semibold">@(ViewBag.EndTimeLocal?.ToString("MMM dd, yyyy HH:mm") ?? "—")</span>
                                    </div>
                                    @if (ViewBag.NowLocal is DateTime now)
                                    {
                                        <div class="d-flex justify-content-between py-2">
                                            <span class="text-muted">Your current time</span>
                                            <span>@now.ToString("MMM dd, HH:mm")</span>
                                        </div>
                                    }
                                </div>
                            </div>
                        </div>
                    }

                    <div class="d-flex flex-wrap gap-3 justify-content-center">
                        <a href="/" class="btn btn-primary px-5">
                            <i class="bi bi-house-door-fill me-2"></i>Home
                        </a>
                        @if (Model != null)
                        {
                            <a asp-controller="Voting" asp-action="PublicResults" asp-route-id="@Model.Id"
                               class="btn btn-outline-primary px-5">
                                <i class="bi bi-bar-chart me-2"></i>View Results
                            </a>
                        }
                    </div>

                </div>
            </div>

            <p class="text-center text-muted small mt-4">
                If you believe this is an error, please contact the election organizer.
            </p>
        </div>
    </div>
</div>
