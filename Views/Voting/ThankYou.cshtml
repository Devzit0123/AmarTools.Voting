@{
    ViewData["Title"] = "Thank You — Vote Recorded";
    Layout = "/Views/Shared/_PublicLayout.cshtml";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-7 col-xl-6 text-center">

            <div class="card shadow border-0 rounded-4 overflow-hidden">
                <div class="card-body py-5 px-4">
                    <div class="mb-3" style="font-size:5.5rem;line-height:1;">
                        <i class="bi bi-check-circle-fill text-success"></i>
                    </div>

                    <h1 class="display-6 fw-bold text-success mb-2">Thank You!</h1>
                    <h5 class="text-muted fw-normal mb-4">Your vote has been successfully recorded.</h5>

                    <p class="lead mb-4">
                        You voted in
                        <strong>@(TempData["ProgramName"] ?? "the voting program")</strong>.
                        Your vote is now secured on the tamper-proof blockchain record.
                    </p>

                    <div class="alert alert-success d-inline-flex align-items-center gap-2 px-4 py-3 mb-4 rounded-3">
                        <i class="bi bi-shield-fill-check fs-5"></i>
                        <span class="fw-semibold">Blockchain verified &amp; immutable</span>
                    </div>

                    <div class="d-flex flex-wrap gap-3 justify-content-center">
                        @if (TempData["ProgramId"] != null)
                        {
                            <a asp-controller="Voting" asp-action="PublicResults" asp-route-id="@TempData["ProgramId"]"
                               class="btn btn-primary btn-lg px-5">
                                <i class="bi bi-bar-chart me-2"></i> View Live Results
                            </a>
                        }
                        <a asp-controller="ProgramOwner" asp-action="MyPrograms" class="btn btn-outline-secondary btn-lg px-5">
                            <i class="bi bi-house-door me-2"></i> My Dashboard
                        </a>
                    </div>

                    <p class="mt-5 text-muted small">Every vote counts — thank you for making your voice heard!</p>
                </div>
            </div>

        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/canvas-confetti@1.9.3/dist/confetti.browser.min.js"></script>
    <script>
        confetti({ particleCount: 120, spread: 70, origin: { y: 0.6 } });
    </script>
}
