@page
@model AmarTools.Voting.Areas.Identity.Pages.Account.LogoutModel

@{
    ViewData["Title"] = "Logout";
    Layout = "/Views/Shared/_AuthLayout.cshtml";
}

<div class="row justify-content-center">
    <div class="col-12 col-md-6 col-lg-4 text-center">
        <div class="card shadow-sm border-0 rounded-3 p-5">
            <i class="bi bi-box-arrow-right" style="font-size:3rem;color:#3b5bdb;"></i>
            <h4 class="mt-3 fw-bold">Signing out...</h4>
            <p class="text-muted">Please wait.</p>
            <form id="logoutForm" method="post">
                @Html.AntiForgeryToken()
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Auto-submit logout form as soon as the page loads
        document.getElementById('logoutForm').submit();
    </script>
}
